DATABASE_URI=postgresql://payloaduser:password@localhost:5432/payloaddb
PAYLOAD_SECRET=YOUR_SECRET_HERE

PAYLOAD_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4000

# Cloudflare R2 Storage (Production only)
# For local development, leave these empty to use local file storage
# For production, fill these with your Cloudflare R2 credentials
R2_BUCKET_NAME=your-bucket-name
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
